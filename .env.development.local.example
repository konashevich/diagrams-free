# Copy to .env.development.local (gitignored) for local Google Drive testing.
VITE_APP_GOOGLE_DRIVE=true
VITE_APP_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# After Worker deploy (optional — enables silent token refresh):
# VITE_APP_GOOGLE_OAUTH_PROXY_URL=https://api.diagrams.free
VITE_APP_GOOGLE_API_KEY=your-referrer-restricted-api-key
VITE_APP_GOOGLE_DRIVE_FOLDER=diagrams.free
